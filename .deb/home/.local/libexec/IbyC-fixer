#!/data/data/com.termux/files/usr/bin/bash
#CREADED ON Dec/2018 BY @IVAM3
#UPGRADED ON 2023/Jan/12
trap ctrl_c 2
ctrl_c(){ printf "$Y\n   [¿] Need a help [?]$B\nTelegram : t.me/Ivam3_Bot$W\n";}
StdErr(){ printf "$R(_➤)$W missing argument, type fixer -h for help\n";exit;}

#:: VARIABLES ::#
IFS=$'\n\t'
iHDB="https://raw.githubusercontent.com/ivam3/i-Haklab/master/.deb/home"
[[ -d $HOME/.local/bin ]] && binPATH="$HOME/.local/bin" || binPATH="$PREFIX/bin"
G=`echo -en "\e[32m"`
R='\e[31m'
Y='\e[33m'
B='\e[34m'
M='\e[35m'
C='\e[36m'
W='\e[0m'

#:: BANNERS ::#
Chao-chao(){ printf "$Y\n[!]-> ::::::::::::::: DONE !! :::::::::::::::: <-[!]$G\n\tTo fix issues going to$B t.me/Ivam3_Bot$W\n";}

running(){
	[[ $1 = "time" ]] && {
		sleep $2 &
		n=$(echo $!);
  }
  [[ $1 = "ps" ]] && {
		n=$2;
  }
  pid=$n
  spinner=( '█■■■■' '■█■■■' '■■█■■' '■■■█■' '■■■■█' )
  while [ "$(ps a|awk '{print $1}'|grep $pid)" ]
	do
		for i in "${spinner[@]}"
		do
			tput civis
			printf  "$G\r(➤_) Running\t$i\b\b\b\b\b\b\b\b";
    done
  done
  tput cnorm
  printf "\t$W[$G¡DONE!$W]\n";
}

Banner(){
	if [[ ! -e $PREFIX/bin/lolcat ]]
	then
		yes|apt install ruby >/dev/null 2>/dev/null
    gem install lolcat >/dev/null 2>/dev/null
  fi
	printf " ___ _            ____     __ _\n|_ _| |__  _   _ / ___|   / _(_)_  _____ _ __\n | || '_ \| | | | |   ___| |_| \ \/ / _ \ '__|\n | || |_) | |_| | |__|___|  _| |>  <  __/ |\n|___|_.__/ \__, |\____|  |_| |_/_/\_\___|_|\n for Termux|___/by @Ivam3byCinderella\n\n"
}

usage() {
	printf "$B\n(USAGE)─➤$G IbyC-fixer <[apt|burpsuite|downgradeRepo|gemini-cli|localtunnel|mariadb|metasploit|ngrok|nrauf|neovim|RuGiR|PyMiR]> <option>$W\n\napt\t\t\t\tSearch and fix some errores on APT/PKG with dpkg\nburpsuite\t\t\tDepends: openjdk-21 but it is not installable\ndowngradeRepo repo=version\tDowngrade apt|pkg reporitory tospecific version\ngemini-cli\t\t\tFix error with pty.node in gemini-cli installation issues\nlocaltunnel\t\t\tfix error 'Unsupported platform: android'\nmariadb\t\t\tfix error 'access denied for user root'\nmetasploit\t\t\tAlternative metasploit installation\nngrok\t\t\t\tInstall ngrok-server from Abhacker repositories\nnrauf         dir/to/app\tTo remapping unicode filenames to ascii when produced by apktool\nneovim\t\t\t\tFix Neovim error: E5108\n\nRuGiR\t\t\t\tFix ruby gems issues\nPyMiR\t\t\t\tFix python module issues\nExamples:\n\tIbyC-fixer RuGiR\n\tIbyC-fixer downgradeRepo ruby=2.7.2\n\tIbyC-fixer nrauf \$HOME/original\n\nFor more help join to$B https://t.me/Ivam3_Bot$W\n\n"
	exit
}

clear;Banner|lolcat
[[ $# -eq 0 ]] && StdErr || arg=($@)
case ${arg[0]} in
	apt)
		file=$(mktemp)
		yes|apt update > $file
		yes|apt upgrade >> $file
		apt clean && apt autoremove
		[[ $(grep -oE "E: Sub-process" $file) ]] && dpkg --configure -a
		[[ $(grep -oE "E: Failed to fetch" $file) ]] || [[ $(grep -oE "E: Unmet" $file) ]] || [[ $(grep -oE "Broken pipe" $file) ]] && apt --fix-broken install
		[[ $(grep -oE "E: Unable to fetch" $file) ]] && apt update --fix-missing
		[[ $(grep -oE "is not signed" $file) ]] || [[ $(grep -oE "NO_PUBKEY" $file) ]] && echo "deb https://packages-cf.termux.org/apt/termux-main/ stable main" > $PREFIX/etc/apt/sources.list;rm -rf $PREFIX/etc/apt/sources.list.d/*;dpkg --configure -a
		rm $file
		;;

    burpsuite)
        yes|pkg i openjdk-21-preinst && openjdk-21-preinst && yes|pkg i burpsuite
        ;;
	
    downgradeRepo)
		[[ -z ${arg[1]} ]] && StdErr
		bash <(curl -fsSL "http://git.io/abhacker-repo") --install ${@:2}
		;;

    gemini-cli)
        export CC=clang 
        export CXX=clang++ 
        export GYP_DEFINES="OS=linux android_ndk_path=." 
        mainDir="${PREFIX}/lib/node_modules/@google/gemini-cli/node_modules/node-pty"
        [[ -d $mainDir ]] || {
            echo -en "$R(_➤)$W gemini-cli is not installed, installing ...\n"
            cd;yes|npm install -g @google/gemini-cli --ignore-scripts --force >/dev/null 2>/dev/null &
            ps=$(echo $!);
            running ps $ps
        }
        pushd $mainDir >/dev/null 2>/dev/null
        npm rebuild --build-from-source >/dev/null 2>/dev/null &
        ps=$(echo $!);
        running ps $ps
        popd >/dev/null 2>/dev/null
        ;;

    localtunnel)
		[[ $(command -v wget) ]] >/dev/null || {
			echo -en "$G(➤_)$W Installing dependencies ...\n"
			yes|apt install wget >/dev/null 2>/dev/null &
			ps=$(echo $!);
			running ps $ps
		}
		echo -en "$G(➤_)$W Fixing ...\n"
		wget --tries=20 --quiet $iHDB/.local/etc/localtunnel/openurl.js -O ${PREFIX}/lib/node_modules/localtunnel/node_modules/openurl/openurl.js &
		ps=$(echo $!)
		running ps $ps
		;;

    mariadb)
        pkill mariadbd 2>/dev/null
        sleep 2

        echo "[*] Staring MariaDB on secure mode (--skip-grant-tables)..."
        mariadbd-safe --skip-grant-tables > /dev/null 2>&1 &

        # Esperar a que el socket esté disponible
        intentos=0
        while ! mariadb-admin ping >/dev/null 2>&1; do
            echo -n "."
            sleep 1
            ((intentos++))
            if [ $intentos -gt 15 ]; then
                echo -e "\n[!] E: Cannot start MariaDB secure mode."
                exit 1
            fi
        done
        echo -e "\n[+] Server on secure mode detected."

        # 3. Ejecutar comandos SQL para resetear root
        echo "[*] Applting patchs for user 'root'..."

        # Nota: Usamos UPDATE en mysql.global_priv para versiones modernas de MariaDB (10.4+)
        # y ALTER/UPDATE en mysql.user para compatibilidad.
        mariadb -u root <<EOF
FLUSH PRIVILEGES;
-- Para versiones < 10.4
ALTER USER 'root'@'localhost' IDENTIFIED BY 'root';
UPDATE mysql.user SET plugin='mysql_native_password' WHERE User='root';
-- Para versiones >= 10.4 (MariaDB usa global_priv)
UPDATE mysql.global_priv SET priv=json_set(priv, '$.plugin', 'mysql_native_password', '$.authentication_string', password('root')) WHERE User='root';
FLUSH PRIVILEGES;
EOF

        if [ $? -eq 0 ]; then
            echo "[+] Privileges 'root' updated."
        else
            echo "[!] Error executing SQL commands."
            pkill mariadbd
            exit 1
        fi

        # 4. Limpiar y reiniciar
        echo "[*] Restaring MariaDB in normal mode..."
        pkill mariadbd
        sleep 2

        mariadbd-safe > /dev/null 2>&1 &
        sleep 3
        ;;

	metasploit)
		[[ -d $PREFIX/var/lib/postgresql ]] && rm -rf $PREFIX/var/lib/postgresql
		bash <(curl -fsSL "http://git.io/abhacker-repo") --install ruby=2.7.2 -r apt install metasploit -y
		yes|apt autoremove
		;;

    neovim)
        [[ -d ~/.local/share/nvim/lazy/bufferline.nvim/lua/bufferline/utils ]] || {
          mkdir -p ~/.local/share/nvim/lazy/bufferline.nvim/lua/bufferline/utils
        }
        wget --tries=20 --quiet $iHDB/.local/share/nvim/lazy/bufferline.nvim/lua/bufferline/utils/init.lua \
          -O ~/.local/share/nvim/lazy/bufferline.nvim/lua/bufferline/utils/init.lua 
        echo -en "$G[DONE!!]$W\n"
		;;

    ngrok)
		printf "$G(_➤)$W Installing Ngrok from Abhacker repositories ...\n"
		bash <(curl -fsSL "http://git.io/abhacker-repo") --install ngrok-server
		printf "$G(_➤)$W Installing official Ngrok executable...\n"
		[[ $(command -v ngrok) ]] && rm -rf $(command -v ngrok)
        arch1=$(uname -a|grep -o 'arm'|head -n1)
        arch2=$(uname -a|grep -o 'Android'|head -n1) 
        [[ $arch1 = 'arm' ]] || [[ $arch2 = 'Android' ]] && arch=arm || arch=386 
        wget -q https://bin.equinox.io/c/4VmDzA7iaHb/ngrok-stable-linux-$arch.zip \
            -O $TMPDIR/ngrok-stable-linux-$arch.zip 
        if [[ -e $TMPDIR/ngrok-stable-linux-$arch.zip ]]; then 
            [[ -d $HOME/.ngrok2 ]] || mkdir -p $HOME/.ngrok2 
            unzip -q $TMPDIR/ngrok-stable-linux-$arch.zip -d $HOME/.ngrok2/ 
            rm -rf $TMPDIR/ngrok-stable-linux-$arch.zip 
            printf "#!/bin/bash\n#THIS SCRIPT EXECUTE NGROK TO AVOID 'bad address' ERROR\nexec termux-chroot $HOME/.ngrok2/ngrok \${@:1}\n#     i-Haklab by Ivam3" > $binPATH/ngrok.io 
            chmod +x $HOME/.ngrok2/ngrok $binPATH/ngrok.io
			echo -en $Y"WARNING:$W Now you have 2 ngrok executables 'ngrok' and 'ngrok.io'\n"
			echo -en "$G[DONE!!]$W\n"
		else
			StdErr
		fi 
        ;; 

    nrauf)
		[[ -z ${arg[1]} ]] && StdErr
		bash <(curl -fsSL "$iHDB/.local/libexec/nrauf") ${arg[2]}
		;;

	PyMiR) bash <(curl -fsSL "${iHDB}/.local/libexec/PyMiR") ${@:2};;
	RuGiR) bash <(curl -fsSL "${iHDB}/.local/libexec/RuGiR") ${@:2};;

	-h|--help) usage;;
	*) StdErr;;
esac

#                                               @Ivam3
