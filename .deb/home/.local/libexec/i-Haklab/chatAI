#!/usr/bin/env bash
IFS=$'\n\t'
trap ctrl_c 2
source ${HOME}/.local/etc/i-Haklab/variables 
source $iHETC/functions

# === Configuración ===
CHAT_DIR="${HOME}/.chatgpt_chats"
ENGINE="${HOME}/.local/libexec/iH-AI.py"
mkdir -p "$CHAT_DIR"

# === Detectar Proveedores Disponibles ===
check_keys() {
    PROVIDERS=()
    [[ -n "$APIKEY_chatGPT" ]] && PROVIDERS+=("OpenAI")
    [[ -n "$APIKEY_Gemini" ]] && PROVIDERS+=("Gemini")
    [[ -n "$APIKEY_Claude" ]] && PROVIDERS+=("Claude")
    
    if [ ${#PROVIDERS[@]} -eq 0 ]; then
        echo -en "$R(>_)$W No API Keys found. Run 'i-Haklab setapikey' first.\n"
        exit 1
    fi
}

select_provider() {
    echo -e "\n$G[?]$W Select AI Provider:"
    select p in "${PROVIDERS[@]}" "Exit"; do
        case $p in
            OpenAI) PROVIDER="openai"; MODEL="gpt-4o-mini"; API_KEY="$APIKEY_chatGPT"; break ;;
            Gemini) PROVIDER="gemini"; MODEL="gemini-1.5-flash"; API_KEY="$APIKEY_Gemini"; break ;;
            Claude) PROVIDER="anthropic"; MODEL="claude-3-5-sonnet-20240620"; API_KEY="$APIKEY_Claude"; break ;;
            Exit) exit 0 ;;
        esac
    done
}

list_chats() {
    echo -en "\n📂 Saved Chats ($PROVIDER):\n"
    local files=("$CHAT_DIR"/*.json)
    if [ ! -e "${files[0]}" ]; then
        echo "(No saved chats)"
        return 1
    fi
    printf "%-3s %-25s %-20s %s\n" "#" "File" "Date" "Size"
    local i=1
    for file in "${files[@]}"; do
        date=$(date -r "$file" "+%m-%d %H:%M")
        size=$(du -h "$file" | awk '{print $1}')
        name=$(basename "$file")
        printf "%-3s %-25s %-20s %s\n" "$i" "$name" "$date" "$size"
        ((i++))
    done
}

select_chat() {
    list_chats
    echo "N) New chat"
    read -rp "Option: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]]; then
        CHAT_FILE=$(ls "$CHAT_DIR"/*.json 2>/dev/null | sed -n "${choice}p")
    else
        read -rp "Name: " name
        [[ -z "$name" ]] && name="chat_$(date +%s)"
        CHAT_FILE="$CHAT_DIR/${name// /_}.json"
        echo '[{"role":"system","content":"Eres una IA en i-Haklab. Responde en español."}]' > "$CHAT_FILE"
    fi
}

show_help() {
    echo -e "\n$G--- AI Commands ---$W"
    echo -e "/model : Change model"
    echo -e "/clear : Reset chat"
    echo -e "/exit  : Exit"
    echo -e "-------------------"
}

# === Inicio ===
banner
check_keys
select_provider
select_chat

echo -e "\n💬 AI CLI $Gv3.0$W | Provider: $Y$PROVIDER$W | Model: $Y$MODEL$W"
echo -e "💡 Type $G/help$W for commands."

while true; do
    echo -en "$B(user)@iH$W: "
    read -r prompt
    [[ -z "$prompt" ]] && continue
    
    case "$prompt" in
        /exit) break ;;
        /help) show_help; continue ;;
        /clear) echo '[{"role":"system","content":"Eres una IA en i-Haklab."}]' > "$CHAT_FILE"; echo "🧹 Cleared."; continue ;;
        /model)
            if [[ "$PROVIDER" == "openai" ]]; then
                echo "1) gpt-4o-mini 2) gpt-4o"; read -rn1 m; [[ $m == 2 ]] && MODEL="gpt-4o" || MODEL="gpt-4o-mini"
            elif [[ "$PROVIDER" == "gemini" ]]; then
                echo "1) gemini-1.5-flash 2) gemini-1.5-pro"; read -rn1 m; [[ $m == 2 ]] && MODEL="gemini-1.5-pro" || MODEL="gemini-1.5-flash"
            fi
            echo -e "\nModel: $MODEL"; continue ;;
    esac

    # Agregar prompt al historial usando jq
    temp_hist=$(jq --arg role "user" --arg content "$prompt" '. + [{"role":$role,"content":$content}]' "$CHAT_FILE")
    echo "$temp_hist" > "$CHAT_FILE"

    # Llamar al motor de Python para el streaming
    python3 "$ENGINE" "$CHAT_FILE" "$PROVIDER" "$MODEL" "$API_KEY"
done

k-boom
