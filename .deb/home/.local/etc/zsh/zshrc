# i-Haklab Zsh Configuration
# Mirrored from .local/etc/fish/config.fish

# Command not found handler
command_not_found_handler() {
    /data/data/com.termux/files/usr/libexec/termux/command-not-found "$1"
}

# Login session (runs i-Haklab login script)
if [[ -o login ]]; then
    bash /data/data/com.termux/files/home/.local/libexec/i-Haklab.login
fi

# Environment Variables
source /data/data/com.termux/files/home/.local/etc/i-Haklab/envvariables

# Fish-like faculties (Predictive Text & Syntax Highlighting)
# Using local i-Haklab plugins for speed and reliability
autoload -Uz compinit && compinit

ZSH_PLUGINS="$HOME/.local/share/zsh/plugins"
[[ -f "$ZSH_PLUGINS/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && source "$ZSH_PLUGINS/zsh-autosuggestions/zsh-autosuggestions.zsh"
[[ -f "$ZSH_PLUGINS/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]] && source "$ZSH_PLUGINS/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# Basic prompt
PROMPT="%F{green}$USER@i-Haklab%f:%F{blue}%~%f$ "
