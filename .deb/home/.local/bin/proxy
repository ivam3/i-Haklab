#!/data/data/com.termux/files/usr/bin/bash
source ${HOME}/.local/etc/i-Haklab/variables
source $iHETC/functions

chk-pkg tor tor
chk-pkg curl curl
chk-pkg privoxy privoxy
chk-pkg proxychains4 proxychains-ng

if [ $# -eq 0 ]; then
    echo -e "\e[4;33musage:\e[0m proxy \e[33m<\e[0moption or command to execute\e[33m>\e[0m\n"
    echo -e "\e[4mOPTIONS\e[0m         \e[4;33mDESCRIPTON\e[0m"
    echo " start     Enable proxy over tor network"
    echo " stop      Disable proxy connection"
    echo "  ip       Get current proxy IP"
    echo " chip      Change current proxy IP"
    echo ""
    echo "  any      Execute any command over tor proxychain"
    echo -e "command    \e[4;33mex:\e[4;0m proxy nmap -p- -Pn 8.8.8.8"
else
    Tor=$(curl --socks5-hostname localhost:9050 \
        -s https://www.google.com > /dev/null;echo $?)

    ip(){ proxychains4 -q curl -s ifconfig.so 2>/dev/null;}

    case "$1" in
        start)
            [[ Tor -eq 0 ]] && {
                echo "Proxy is activated"
            } || {
                privoxy --no-daemon $PREFIX/etc/privoxy/config &>/dev/null 2>$LOGFILE &
                tor >/dev/null 2>/dev/null &
                sleep 6
                echo -en "Proxy enable over:  \b";ip;
            }
            ;;
        stop)
            [[ Tor -eq 0 ]] && {
                pkill privoxy &>/dev/null
                killall tor 2>/dev/null
                echo "Proxy stoped.";
            } || {
                echo "Proxy is disabled.";
            }
            ;;
        ip)
            [[ Tor -eq 0 ]] && {
                echo -en "Proxy ip:  \b";ip;
            } || {
                echo "Proxy is disabled.";
            }
            ;;
        chip)
            [[ Tor -eq 0 ]] && {
                killall -HUP --quiet tor &>/dev/null
                sleep 2
                echo -en "IP proxy changed at:  \b";ip;
            } || {
                echo "Proxy is disabled.";
            }
            ;;
        *)
            [[ Tor -eq 0 ]] && {
                if command -v $1 >/dev/null -o -e $1
                then
                    echo -en $Y"Proxy over:$W  \b";ip
                    echo
                    proxychains4 -q ${@:1} 2>/dev/null
                else
                    echo -en $R"E:$W $1 is not an executable."
                fi
            } || {
                echo "Proxy is disabled.";
            }
            ;;
    esac
fi
