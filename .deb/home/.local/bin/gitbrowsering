#!/data/data/com.termux/files/usr/bin/env python

import requests

def get_github_links(keyword):
    url = f"https://api.github.com/search/repositories?q={keyword}&per_page=100"
    links = []

    while url:
        response = requests.get(url)
        if response.status_code == 200:
            data = response.json()
            repositories = data.get('items', [])
            if not repositories:
                break
            links.extend(repo['html_url'] for repo in repositories)
            if 'next' in response.links:
                url = response.links['next']['url']
            else:
                url = None
        else:
            print(f"Error: No se pudo obtener la informaciГіn de GitHub. CГіdigo de estado: {response.status_code}")
            break

    return links

