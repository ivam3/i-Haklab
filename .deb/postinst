#!/data/data/com.termux/files/usr/bin/bash
IFS=$'\n\t'
# INVOKE VARIABLES AND FUNCTIONS
source ${HOME}/.local/etc/i-Haklab/variables
source $iHETC/functions
fontsV="v2.3.3"
z=$(sleep 0.5)
prevpass=$(cat ${HOME}/.local/etc/i-Haklab/.Ivam3byCinderella 2>/dev/null | openssl enc -aes-256-cbc -md sha512 -a -d -pbkdf2 -iter 100000 -salt -pass pass:Secret@123# 2>/dev/null) 

# PREINST
[[ -e ${PREFIX}/etc/bashito ]] && { rm -rf ${PREFIX}/etc/bashito;}
[[ -e ${PREFIX}/etc/motd ]] && { rm -rf ${PREFIX}/etc/motd;}
[[ -e ${PREFIX}/etc/motd.dpkg-old ]] && { rm -rf ${PREFIX}/etc/motd.dpkg-old;}

# BACKUPING PREVIOUS SETTINGS
if [[ -e $HOME/.local/etc/i-Haklab/.Ivam3byCinderella ]]; then
  echo "Keeping previous password ..."
  [[ $prevpass != "Ivam3byCinderella" ]] && {
    cp ${HOME}/.local/etc/i-Haklab/.Ivam3byCinderella ${TMPDIR}/.IbyC
  }
fi

if [[ -e ${HOME}/.local/libexec/i-Haklab.login ]]; then
  echo "Keeping previous settings ..."
  cp ${HOME}/.local/libexec/i-Haklab.login ${TMPDIR}/i-Haklab.login.backup
fi

# BACKUPING PREVIOUS API KEYS
if [[ -e ${HOME}/.local/etc/i-Haklab/variables ]]; then
  echo "Keeping previous API keys ..."
  grep '^export APIKEY_' "${HOME}/.local/etc/i-Haklab/variables" > "${TMPDIR}/.ihabak-apikeys"
fi

# TOOLS STORAGE DIRECTORY (INTERNAL - EXTERNAL)
echo "Getting access to external storage.";$z
mkdir -p ${HOME}/go/bin
s2=$(df|grep "fuse"|grep -iv emulated|awk -F " " '{print $6}')
[[ -n $s2 ]] && [[ -w $s2 ]] && {
	[[ -d $s2/Android/data/com.termux/files/tools ]] && [[ -s $s2/Android/data/com.termux/files/tools ]] && {
		for tool in "$s2/Android/data/com.termux/files/tools/"*; do
			[[ -e "$tool" ]] && mv "$tool" ${HOME}/.local/share/
		done
	}
}

echo "Installing required python modules (It could take a while) ...";$z
for module in beautifulsoup4 betrufflehog frida pipenv pyyaml shodan speedtest-cli wheel;do
	python3 -m pip --no-color --quiet --no-cache-dir install $module 2>>$LOGFILE
done

echo "Installing required nodejs modules (It could take a while) ...";$z
corepack enable
npm install -g pnpm localtunnel bash-language-server 2>>$LOGFILE

[[ -d ${HOME}/.local/share/wordlist ]] || { 
    mkdir -p ${HOME}/.local/share/wordlist
}

echo "Setting website '4share'."
curl --create-dirs -fsSL $iHDB/.local/var/service/www/veno-file-manager/vfm/vfm-admin/assets/zipstream/phpzip/phpzip/tests/run%20functional%20tests.bat -o ${HOME}/.local/var/service/www/veno-file-manager/vfm/vfm-admin/assets/zipstream/phpzip/phpzip/tests/'run functional tests.bat'
curl --create-dirs -fsSL $iHDB/.local/var/service/www/veno-file-manager/vfm/vfm-admin/assets/zipstream/phpzip/phpzip/tests/run%20unit%20tests.bat -o ${HOME}/.local/var/service/www/veno-file-manager/vfm/vfm-admin/assets/zipstream/phpzip/phpzip/tests/'run unit tests.bat'
chmod 777 -R ${HOME}/.local/var/service/www/veno-file-manager/vfm/vfm-admin/assets/zipstream/phpzip/phpzip/tests

# SET OMF SHELL
echo "Setting interactive shell Oh-my-fish.";$z
#git config --global core.autocrlf
[[ -e ${HOME}/.local/share/omf ]] && rm -rf ${HOME}/.local/share/omf
[[ -e ${PREFIX}/etc/fish/config.fish ]] && rm ${PREFIX}/etc/fish/config.fish
[[ -e ${HOME}/.config/fish/conf.d/omf.fish ]] && rm ${HOME}/.config/fish/conf.d/omf.fish
[[ -e ${PREFIX}/bin/fish ]] && [[ ! -L ${HOME}/.termux/shell ]] && {
	ln -s ${PREFIX}/bin/fish $HOME/.termux/shell;
}
ln -s ${HOME}/.local/etc/fish/config.fish ${PREFIX}/etc/fish/config.fish
[[ $(grep 'fish' -oE ${PREFIX}/etc/bash.bashrc) ]] || {
	sed -i '12a chsh -s fish' ${PREFIX}/etc/bash.bashrc;
}
[[ -e ${HOME}/.bashrc ]] && { mv ${HOME}/.bashrc ${HOME}/.bashrc.bak;}
ln -s "${HOME}/.local/etc/bash/bashrc" ${HOME}/.bashrc
fish <(curl -fsSL "$iHDB/.local/etc/i-Haklab/get.oh-my.fish")

file=$(mktemp)
chmod 777 $file
cat <<- CONF > $file
#!/bin/env fish
omf install will
CONF
fish $file >/dev/null 2>>$LOGFILE
rm $file

## SETTING FONTS AS DejaVuSansMono
[[ -d ${PREFIX}/share/fonts/ ]] && {
  rm -rf ${PREFIX}/share/fonts/*
} || {
  mkdir -p ${PREFIX}/share/fonts
}
for i in ProFont Hack; do
   curl -fsSL https://github.com/ryanoasis/nerd-fonts/releases/download/$fontsV/$i.zip \
    -o ${PREFIX}/share/fonts/$i.zip
  if [[ -e ${PREFIX}/share/fonts/$i.zip ]]; then
    unzip -qo ${PREFIX}/share/fonts/$i.zip -d ${PREFIX}/share/fonts/
    rm -rf ${PREFIX}/share/fonts/$i.zip
  else
    echo -en "${R}E:$W Fonts ${i}.zip file is missing or unreacheble."
  fi
done

# SET ROOT USER IF DEVICE IS ROOTED
if chk-root;then
	echo "Rooted device detected, setting Root user ...";$z
	rm -rf ${HOME}/.config/fish/functions/sudo.fish
	ln -s ${PREFIX}/bin/applets/sudo ${PREFIX}/bin/sudo
	if [[ -e ${HOME}/.suroot/.bashrc ]]
	then
		[[ -O ${HOME}/.suroot/.bashrc ]] || sudo chown $USER:$USER -R ${HOME}/.suroot/
  else
		[[ -d ${HOME}/.suroot ]] || mkdir ${HOME}/.suroot
  fi
  cat <<- CONF > ${HOME}/.suroot/.bashrc
PS1="\[\e[33m\][!] \[\e[31m\]Press\[\e[32m\] Ctrl d\[\e[31m\] to log out\[\e[32m\] ➤ \[\e[m\]"
export TERM=xterm-256color
export LD_LIBRARY_PATH=/data/data/com.termux/files/usr/lib
export PATH=$HOME/go/bin:/data/data/com.termux/files/usr/bin:/data/data/com.termux/files/usr/bin/applets:/system/xbin:/system/bin
HOME=/data/data/com.termux/files/home/.suroot
fish
#          i-Haklab by @Ivam3
CONF
fi

echo "Getting permissions ..."
chmod u+x -R ${HOME}/.local/* ${HOME}/.config/fish/functions/* ${PREFIX}/bin/* 2>>$LOGFILE

echo "Updating mlocate data base ..."
updatedb

# RESTORE PREVIOUS PASSWORD IF DEFAULT WAS CHANGED
if [[ -e ${TMPDIR}/.IbyC ]]; then 
    echo "Restoring previous password."
	cat ${TMPDIR}/.IbyC > ${HOME}/.local/etc/i-Haklab/.Ivam3byCinderella
	rm -f ${TMPDIR}/.IbyC
fi

# RESTORE PREVIOUS LOGIN SETTING IF DEFAULT WAS CHANGED
if [[ -e ${TMPDIR}/i-Haklab.login.backup ]]; then 
    echo "Restoring previous settings"
	cat ${TMPDIR}/i-Haklab.login.backup > ${HOME}/.local/libexec/i-Haklab.login
	rm ${TMPDIR}/i-Haklab.login.backup
fi

# RESTORE PREVIOUS API KEYS
if [[ -s ${TMPDIR}/.ihabak-apikeys ]]; then
  echo "Restoring previous API keys ..."
  awk '
    NR==FNR {
      eq = index($0, "=")
      varname = substr($0, 8, eq - 8)
      keys[varname] = $0
      next
    }
    /^export APIKEY_/ {
      eq = index($0, "=")
      varname = substr($0, 8, eq - 8)
      if (varname in keys) {
        print keys[varname]
        next
      }
    }
    { print }
  ' "${TMPDIR}/.ihabak-apikeys" "$HOME/.local/etc/i-Haklab/variables" > "${TMPDIR}/.ihabak-vars-new" && \
  mv "${TMPDIR}/.ihabak-vars-new" "$HOME/.local/etc/i-Haklab/variables"
  rm -f "${TMPDIR}/.ihabak-apikeys"
fi

echo -en "[deleted]
    ╰──➤ Commands:
    |\t\t• i-Haklab chatGPT (changed at 'chatAI')
[updates]
    ╰──➤ Commands recently added:
    |\t\t• yazi - terminal file manager
    |\t\t• qemufy
    |\t\t• phantom-ps
    |\t\t• i-Haklab chatAI (before 'chatGPT')
    ╰──➤ New features:
    |\t\t• shell: now i-Haklab works over shells fish, zsh & bash \n\t\t\t   run 'i-Haklab setshell' to set it
    |\t\t• chatAI: LLM availables: chatGPT, Gemini & Claude | Mannage 2+ chats \n\t\t\t   create image | remember conversation
    |\t\t• Into neovim: type 'alter', 'comma', 'ca' | (alt + , + n) to use AI
[Artificial Intellient]
    ╰──➤ Agents:
    |\t\t• N8N
    |\t\t• Opencode
    |\t\t• Mimocode
    |\t\t• Openclaw
    |\t\t• Codebuff
    |\t\t• Freebuff
    |\t\t• Codex-cli
    |\t\t• Qwen-code
    |\t\t• Claude-code
    |\t\t• Minimax-cli 
    |\t\t• Hermes-agent
    |\t\t• Mistral-vibe
    |\t\t• Open-lovable
    |\t\t• Github Copilot
    |\t\t• Antigravity-cli
    ╰──➤ MCPs:
    |\t\t• Testsprite
    |\t\t• Context7
    |\t\t• Engram
    |\t\t• Smithery
    ╰──➤ Skills:
    |\t\t• Termux-oracle-skill
    |\t\t• GH (github-cli)
    |\t\t• Context7
    |\t\t• Playwrigth-cli
    |\t\t• Termux-api
    |\t\t• Use-railway"
echo "[*] i-Haklab installation finished."
echo "[*] run 'i-Haklab help' for a guide."
echo "[-] Run 'fixer' to fix any posible issue."
